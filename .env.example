# Cloudflare Workers AI credentials
# Get these from: https://dash.cloudflare.com → Workers AI → Use REST API
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_API_TOKEN=your_api_token

# Optional: override default model names
# AI_IMAGE_INDEXER_VISION_MODEL=@cf/unum/uform-gen2-qwen-500m
# AI_IMAGE_INDEXER_EMBEDDING_MODEL=@cf/google/embeddinggemma-300m

# Optional: database location (default: ~/.ai-image-indexer/index.db)
# AI_IMAGE_INDEXER_DB_PATH=~/.ai-image-indexer/index.db

# Optional: comma-separated folders to scan (default: OS image folders)
# AI_IMAGE_INDEXER_SCAN_PATHS=C:\Users\You\Pictures,D:\Photos
